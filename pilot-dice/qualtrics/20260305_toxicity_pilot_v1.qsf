t"},"QuestionDescription":"Did you know the M&M's brand before?","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID57"}},{"SurveyID":"SV_8rnrq4PRm5C4ijk","Element":"SQ","PrimaryAttribute":"QID58","SecondaryAttribute":"Choose one or more races that you consider yourself to be.","TertiaryAttribute":null,"Payload":{"QuestionText":"Choose one or more races that you consider yourself to be.","DataExportTag":"ethnicity","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Choose one or more races that you consider yourself to be.","Choices":{"1":{"Display":"White or Caucasian"},"2":{"Display":"Black or African American"},"3":{"Display":"American Indian\/Native American or Alaska Native"},"4":{"Display":"Asian"},"5":{"Display":"Native Hawaiian or Other Pacific Islander"},"6":{"Display":"Other","TextEntry":"true"},"7":{"Display":"Prefer not to say"}},"ChoiceOrder":["1","2","3","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID58","Randomization":{"Type":"Advanced","Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","6","7"],"RandomizeAll":["1","2","3","4","5"],"RandomSubSet":[],"ScaleReversal":[],"Undisplayed":[],"TotalRandSubset":0},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":""}}},{"SurveyID":"SV_8rnrq4PRm5C4ijk","Element":"SQ","PrimaryAttribute":"QID59","SecondaryAttribute":"We have shown you an advertisement promoting M&M's. The following questions will ask about your a...","TertiaryAttribute":null,"Payload":{"QuestionText":"We have shown you an advertisement promoting M&amp;M's. The following questions will ask about your attitude towards this brand. Please reflect on your overall impressions and any thoughts or feelings you associate with M&amp;M's based on the advertisement.","DefaultChoices":false,"DataExportTag":"Briefing","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"We have shown you an advertisement promoting M&M's. The following questions will ask about your a...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID59"}},{"SurveyID":"SV_8rnrq4PRm5C4ijk","Element":"SQ","PrimaryAttribute":"QID60","SecondaryAttribute":"Thank you for participating in our study. We appreciate your time and valuable responses. We woul...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for participating in our study. We appreciate your time and valuable responses. We would like to clarify that the advertisement for M&amp;M's, which you saw during this study, was fictitious. The ad was specifically created for the purpose of this research. The study aimed to understand how the context in which an advertisement is seen can affect people's attitudes toward a brand. It is important to note that the scenarios presented were simulated to assess the impact of potentially sensitive contexts on brand perception.\n<br><br>As part of the study, the M&amp;M's ad promoted a $35 voucher and invited participants to enter a raffle. While the ad itself was fictitious, the incentive is real: we will randomly select one participant and contact them via Prolific to send a gift code for snackboxusa.com to purchase snacks.\n<br><br>Please click the button below to be redirected to Prolific and register your submission.","DefaultChoices":false,"DataExportTag":"debrief","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for participating in our study. We appreciate your time and valuable responses. We woul...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID60"}},{"SurveyID":"SV_8rnrq4PRm5C4ijk","Element":"SQ","PrimaryAttribute":"QID61","SecondaryAttribute":"Please share your thoughts about the study. (e.g., aspects you particularly liked, disliked, or a...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please share your thoughts about the study.<br \/>\n<span style=\"font-size:11px;\"><em>(e.g., aspects you particularly liked, disliked, or anything that could help us improve it.)<\/em><\/span>","DefaultChoices":false,"DataExportTag":"otf","QuestionType":"TE","Selector":"ML","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please share your thoughts about the study. (e.g., aspects you particularly liked, disliked, or a...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID61"}},{"SurveyID":"SV_8rnrq4PRm5C4ijk","Element":"SQ","PrimaryAttribute":"QID62","SecondaryAttribute":"Please respond honestly, did you notice the M&M's ad in the feed?\u00a0 Your response will not affect...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please respond honestly, did you notice the M&amp;M's ad in the feed?&nbsp;<br><br>Your response will not affect your compensation or study completion.<br>","DataExportTag":"declaration","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please respond honestly, did you notice the M&M's ad in the feed?\u00a0 Your response will not affect...","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID62"}},{"SurveyID":"SV_8rnrq4PRm5C4ijk","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":false,"ID":"Survey Statistics"}}]}