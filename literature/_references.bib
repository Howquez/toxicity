@article{TomainoEtAl_2025,
  author = {Tomaino, Geoff and Mazar, Asaf and Carmon, Ziv and Wertenbroch, Klaus},
  title = {A simple method for improving generalizability in behavioral science: Scope Testing with AI-Generated Stimuli (STAGS)},
  journal = {Consumer Psychology Review},
  volume = {8},
  number = {1},
  pages = {87-97},
  keywords = {artificial intelligence, experimental design, GenAI, generalizability, representative design},
  doi = {https://doi.org/10.1002/arcp.1101},
  url = {https://myscp.onlinelibrary.wiley.com/doi/abs/10.1002/arcp.1101},
  eprint = {https://myscp.onlinelibrary.wiley.com/doi/pdf/10.1002/arcp.1101},
  abstract = {Abstract Behavioral research typically tests hypotheses in a limited set of researcher-selected contexts. This approach can reveal whether an effect can occur (possibility) but does not indicate whether it holds in other contexts (generalizability). We present Scope Testing with AI-Generated Stimuli (STAGS), a simple approach that uses Generative AI (GenAI) to test predictions across a range, or scope, of stimuli. By assessing whether a prediction holds across this range, STAGS sheds light on the generalizability of the effect. In addition, outsourcing stimulus generation to GenAI makes transparent the otherwise opaque process of stimulus selection, requiring researchers to articulate the scope of stimuli to which their hypothesis applies. We illustrate STAGS in an experiment, showing that specifying the population from which stimuli are sampled can help researchers understand the scope of the effect they are studying. We discuss the benefits and limitations of this approach and propose directions for future exploration.},
  year = {2025}
}



